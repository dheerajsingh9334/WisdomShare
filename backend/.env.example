# =========================
# Backend Environment (Local Example)
# =========================

# App
NODE_ENV=development
PORT=5000

# Database
# Use either MONGO_URL or MONGODB_URI (both are referenced in code)
MONGO_URL=mongodb://127.0.0.1:27017/wisdomshare
MONGODB_URI=mongodb://127.0.0.1:27017/wisdomshare

# Redis (BullMQ + cache)
REDIS_URL=redis://127.0.0.1:6379

# Auth / JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5173
# Comma-separated extra origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/users/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Gemini AI
# You can use either key name
GEMINI_API_KEY=replace_with_gemini_api_key
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Email (Gmail SMTP preferred in current code)
GMAIL_USER=youremail@gmail.com
GMAIL_PASS=your_gmail_app_password
# Optional fallbacks used in some files
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_email_password
ADMIN_EMAIL=admin@example.com

# Admin bootstrap
ADMIN_REGISTRATION_CODE=SUPER_ADMIN_2024_SECURE

# Optional app/admin settings used by admin endpoints
SITE_NAME=WisdomShare
SITE_DESCRIPTION=Share your wisdom with the world
MAINTENANCE_MODE=false
REGISTRATION_ENABLED=true
MAX_FILE_SIZE=5
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp
DEFAULT_USER_ROLE=user
MAX_POSTS_PER_USER=100
MAX_COMMENTS_PER_POST=50
AUTO_MODERATION_ENABLED=false
EMAIL_NOTIFICATIONS=true
PUSH_NOTIFICATIONS=true
ADMIN_NOTIFICATIONS=true

# Optional fallback base URL used by some mail helpers
BASE_URL=http://localhost:5173
